@'
{
  "version": 2,
  "functions": {
    "gbaki_backend/wsgi.py": {
      "maxDuration": 30,
      "runtime": "python3.12"
    }
  },
  "buildCommand": "pip install -r requirements.txt && python vercel_build.py",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "gbaki_backend/wsgi.py"
    }
  ]
}
'@ | Set-Content -Encoding UTF8 vercel.json