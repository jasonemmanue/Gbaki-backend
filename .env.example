# ── Sécurité Django ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=remplace-par-une-vraie-cle-secrete-longue
DEBUG=False
ALLOWED_HOSTS=ton-projet.vercel.app

# ── Base de données — Neon PostgreSQL (neon.tech, gratuit) ────────────────────
# Après création sur neon.tech, coller l'URL ici ET dans les variables Vercel
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET_NAME=gbaki-documents
CF_R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CF_R2_PRESIGN_EXPIRY=3600

# ── Email Gmail ────────────────────────────────────────────────────────────────
EMAIL_HOST_USER=ton-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL=True
